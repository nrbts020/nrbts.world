---
// Serial — portfolio recreation of an offline magazine site.
// Design system supplied directly by the user (sabukaru-inspired layout,
// Tadao Ando material sensibility — concrete/steel palette, wide-tracked
// mono caps, full-bleed photo grids, monochrome-by-intent). This layout
// hosts the shared chrome (fonts, CSS custom properties, every class name
// the Serial components render into) so components stay thin markup +
// props rather than each carrying its own scoped copy of the system —
// Astro's per-component style scoping would otherwise break cross-
// component class matching (e.g. ImageGrid's .tile needs to line up with
// rules defined once, not six times).
//
// Real photography doesn't exist for these articles yet (the original
// Serial site is offline and this is a from-scratch recreation), so every
// image-bearing component accepts either a real {src, alt} or a
// `placeholder` array of lines and renders a labelled placeholder tile —
// same "here's where the real asset goes" convention already used
// elsewhere on the site (.proj-classified on the homepage). Swap in real
// photos later without touching the component API.
//
// Kept outside the main portfolio's Three.js scene entirely (mobile-
// performance constraint) — this is a pure content subsection, same
// pattern as /writing, /photography, /uncancel.
interface Props {
	title: string;
	description?: string;
}

const { title, description = "Serial — gear, film, culture." } = Astro.props;
---

<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Archivo:wght@500;600;700&family=Space+Mono:wght@400;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<div id="prog"></div>

		<!-- Portfolio wayfinding — same floating pill used on the other
		     dedicated subpages (photography/uncancel/writing), layered above
		     Serial's own sticky nav so there's always a way back out. -->
		<nav class="site-nav" aria-label="Section navigation">
			<a href="/">&larr; beats.dev</a>
		</nav>

		<slot />

		<script>
			// Thin scroll-progress hairline under the sticky nav — same trick
			// as the original mockup, kept as vanilla JS/no deps.
			const prog = document.getElementById("prog");
			if (prog) {
				addEventListener(
					"scroll",
					() => {
						const h = document.documentElement;
						const m = h.scrollHeight - h.clientHeight;
						(prog as HTMLElement).style.width = (m > 0 ? (h.scrollTop / m) * 100 : 0) + "%";
					},
					{ passive: true }
				);
			}
		</script>

		<style is:global>
			:root {
				--paper: #e4e5e4; /* cold concrete day-mode */
				--ink: #1b1e20; /* cool near-black / steel */
				--ink2: #3c4145;
				--mute: #7e8488; /* steel grey */
				--hair: #1b1e20;
				--img: #c3c7c8; /* cool concrete placeholder */
				--form: #f2f3f2; /* poured-concrete light plane */

				/* Serial pages sit outside the main portfolio's Mirror's Edge
				   scene entirely — its own --bg is just the concrete paper, not
				   the site-wide --bg/--teal tokens. */
			}
			* {
				margin: 0;
				padding: 0;
				box-sizing: border-box;
			}
			html {
				scroll-behavior: smooth;
			}
			body {
				background: var(--paper);
				color: var(--ink);
				font-family: "IBM Plex Mono", monospace;
				font-size: 15px;
				line-height: 1.7;
				-webkit-font-smoothing: antialiased;
				overflow-x: hidden;
			}
			.caps {
				font-family: "Space Mono", monospace;
				text-transform: uppercase;
				letter-spacing: 0.22em;
			}
			.brandf {
				font-family: "Archivo", sans-serif;
				font-weight: 600;
			}

			#prog {
				position: fixed;
				top: 0;
				left: 0;
				height: 2px;
				width: 0;
				background: var(--ink);
				z-index: 100;
			}

			/* Portfolio wayfinding pill — matches photography.astro/uncancel.astro's
			   .site-nav exactly, just re-declared here since Serial pages don't
			   share index.astro's --bg/--nav-* tokens. */
			.site-nav {
				position: fixed;
				top: max(14px, env(safe-area-inset-top));
				left: max(14px, env(safe-area-inset-left));
				display: flex;
				gap: 4px;
				padding: 6px;
				background: rgba(27, 30, 32, 0.82);
				border: 1px solid rgba(228, 229, 228, 0.25);
				border-radius: 2px;
				backdrop-filter: blur(6px);
				-webkit-backdrop-filter: blur(6px);
				z-index: 101;
			}
			.site-nav a {
				color: rgba(228, 229, 228, 0.92);
				text-decoration: none;
				font: 500 12px/1 "IBM Plex Mono", monospace;
				letter-spacing: 0.02em;
				padding: 8px 12px;
				touch-action: manipulation;
			}
			.site-nav a:hover,
			.site-nav a:focus-visible {
				color: #fff;
				background: rgba(255, 255, 255, 0.16);
			}

			/* ---- nav: minimal, sabukaru-style ---- */
			header.nav {
				position: sticky;
				top: 0;
				z-index: 60;
				background: var(--paper);
				display: flex;
				align-items: center;
				justify-content: space-between;
				padding: 20px 26px;
				border-bottom: 1px solid var(--ink);
			}
			.logo {
				display: flex;
				align-items: center;
				gap: 11px;
				text-decoration: none;
				color: var(--ink);
			}
			.logo .mk {
				width: 26px;
				height: 26px;
				background: var(--ink);
				color: var(--paper);
				display: flex;
				align-items: center;
				justify-content: center;
				font-family: "Archivo", sans-serif;
				font-size: 14px;
				font-weight: 700;
				clip-path: polygon(0 0, 100% 0, 100% 78%, 78% 100%, 0 100%);
			}
			.logo .nm {
				font-family: "Archivo", sans-serif;
				font-weight: 700;
				font-size: 20px;
				letter-spacing: 0.28em;
				text-transform: uppercase;
			}
			nav.links {
				display: flex;
				gap: 30px;
			}
			nav.links a {
				font-family: "Space Mono", monospace;
				font-size: 12px;
				letter-spacing: 0.18em;
				text-transform: uppercase;
				color: var(--ink);
				text-decoration: none;
			}
			nav.links a:hover {
				opacity: 0.5;
			}
			.burger {
				display: none;
				background: none;
				border: none;
				font-size: 20px;
				cursor: pointer;
				color: var(--ink);
			}

			/* ---- full-bleed hero ---- */
			.hero {
				position: relative;
				width: 100%;
				height: 86vh;
				min-height: 560px;
				background: var(--img);
				overflow: hidden;
				border-bottom: 1px solid var(--ink);
			}
			.hero img {
				position: absolute;
				inset: 0;
				width: 100%;
				height: 100%;
				object-fit: cover;
				display: block;
			}
			.hero .ph {
				position: absolute;
				inset: 0;
				display: flex;
				align-items: center;
				justify-content: center;
				text-align: center;
			}
			/* Contrast guarantee for the dark kicker/category/title sitting on
			   top of a real photo — a top wash for the kicker/cat corners and
			   a taller bottom wash for the title (title can wrap to 2 lines on
			   narrow viewports, hence the generous 46% fade height). Sits in
			   the DOM between the image and the text, so it layers above the
			   photo but stays behind the copy. */
			.hero .scrim {
				position: absolute;
				inset: 0;
				pointer-events: none;
				background:
					linear-gradient(to bottom, rgba(228, 229, 228, 0.55) 0%, rgba(228, 229, 228, 0) 22%),
					linear-gradient(to top, rgba(228, 229, 228, 0.88) 0%, rgba(228, 229, 228, 0.5) 22%, rgba(228, 229, 228, 0) 46%);
			}
			.hero .ph span {
				font-family: "Space Mono", monospace;
				font-size: 12px;
				letter-spacing: 0.2em;
				color: var(--mute);
				text-transform: uppercase;
				line-height: 2;
			}
			.hero .cat {
				position: absolute;
				top: 22px;
				right: 26px;
				font-family: "Space Mono", monospace;
				font-size: 12px;
				letter-spacing: 0.2em;
				text-transform: uppercase;
				color: var(--ink);
			}
			.hero .htitle {
				position: absolute;
				left: 26px;
				right: 26px;
				bottom: 34px;
				font-family: "Space Mono", monospace;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.16em;
				line-height: 1.14;
				font-size: clamp(22px, 4.4vw, 54px);
				color: var(--ink);
			}
			.hero .kicker {
				position: absolute;
				left: 26px;
				top: 22px;
				font-family: "Space Mono", monospace;
				font-size: 12px;
				letter-spacing: 0.2em;
				text-transform: uppercase;
			}

			/* ---- full-bleed image grid (sabukaru signature) ---- */
			.grid2 {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 0;
			}
			.grid3 {
				display: grid;
				grid-template-columns: 1fr 1fr 1fr;
				gap: 0;
			}
			.gridwide {
				display: grid;
				grid-template-columns: 1fr;
			}
			.tile {
				position: relative;
				background: var(--img);
				aspect-ratio: 4 / 5;
				overflow: hidden;
				border-right: 1px solid var(--ink);
				border-bottom: 1px solid var(--ink);
			}
			.tile img {
				position: absolute;
				inset: 0;
				width: 100%;
				height: 100%;
				object-fit: cover;
				display: block;
			}
			.grid2 .tile:last-child,
			.grid3 .tile:last-child {
				border-right: none;
			}
			.tile .ph {
				position: absolute;
				inset: 0;
				display: flex;
				align-items: center;
				justify-content: center;
				text-align: center;
				padding: 16px;
			}
			.tile .ph span {
				font-family: "Space Mono", monospace;
				font-size: 11px;
				letter-spacing: 0.18em;
				color: var(--mute);
				text-transform: uppercase;
				line-height: 2;
			}
			.tile .tag {
				position: absolute;
				bottom: 14px;
				right: 16px;
				font-family: "Space Mono", monospace;
				font-size: 11px;
				letter-spacing: 0.18em;
				text-transform: uppercase;
				color: var(--ink);
				background: var(--paper);
				padding: 2px 7px;
			}
			.tile.wide {
				aspect-ratio: 16 / 7;
				border-right: none;
			}

			/* ---- text sections ---- */
			.wrap {
				max-width: 1100px;
				margin: 0 auto;
				padding: 0 26px;
			}
			.section {
				padding: 64px 0 0;
			}
			.lede {
				font-family: "IBM Plex Mono", monospace;
				font-size: 19px;
				line-height: 1.7;
				max-width: 760px;
				margin: 0 auto;
				color: var(--ink);
			}
			.lede .drop {
				font-family: "Archivo", sans-serif;
				font-weight: 600;
			}
			.body {
				max-width: 760px;
				margin: 0 auto;
			}
			.body p {
				margin-bottom: 22px;
			}
			.body p a {
				color: var(--ink);
				text-decoration: underline;
				text-underline-offset: 3px;
			}

			.shead {
				max-width: 760px;
				margin: 64px auto 26px;
				display: flex;
				align-items: baseline;
				gap: 16px;
				border-top: 1px solid var(--ink);
				padding-top: 20px;
			}
			.shead .n {
				font-family: "Space Mono", monospace;
				font-size: 12px;
				letter-spacing: 0.2em;
				text-transform: uppercase;
			}
			.shead h2 {
				font-family: "Space Mono", monospace;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.14em;
				font-size: clamp(17px, 2.3vw, 24px);
				line-height: 1.2;
			}

			.pull {
				max-width: 900px;
				margin: 56px auto;
				text-align: center;
				font-family: "Archivo", sans-serif;
				font-weight: 600;
				font-size: clamp(22px, 3.2vw, 36px);
				line-height: 1.24;
				letter-spacing: -0.01em;
				color: var(--ink);
				padding: 0 26px;
			}

			/* spec block: austere mono spec sheet, full width */
			.lens {
				border-top: 1px solid var(--ink);
				max-width: 760px;
				margin: 0 auto;
			}
			.lens:last-of-type {
				border-bottom: 1px solid var(--ink);
			}
			.lens .lh {
				display: flex;
				justify-content: space-between;
				align-items: baseline;
				padding: 18px 0 8px;
			}
			.lens .lh .nm {
				font-family: "Space Mono", monospace;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.12em;
				font-size: 15px;
			}
			.lens .lh .sn {
				font-family: "Space Mono", monospace;
				font-size: 11px;
				letter-spacing: 0.14em;
				text-transform: uppercase;
				color: var(--mute);
			}
			.lens .lrow {
				display: grid;
				grid-template-columns: 110px 1fr;
				font-size: 13.5px;
				border-top: 1px dotted var(--mute);
				padding: 7px 0;
			}
			.lens .lrow .k {
				color: var(--mute);
				text-transform: uppercase;
				letter-spacing: 0.1em;
				font-size: 12px;
			}
			.lens .lcopy {
				padding: 14px 0 20px;
				font-size: 14.5px;
				line-height: 1.65;
				max-width: 640px;
			}
			.verdict {
				display: inline-block;
				font-family: "Space Mono", monospace;
				font-size: 11px;
				letter-spacing: 0.16em;
				text-transform: uppercase;
				border: 1px solid var(--ink);
				padding: 3px 9px;
				margin-top: 12px;
			}

			/* rating strip */
			.rate {
				max-width: 760px;
				margin: 56px auto 0;
				display: grid;
				border: 1px solid var(--ink);
				background: var(--form);
			}
			.rate .rc {
				padding: 20px 12px;
				border-right: 1px solid var(--ink);
				text-align: center;
			}
			.rate .rc:last-child {
				border-right: none;
			}
			.rate .rl {
				font-family: "Space Mono", monospace;
				font-size: 10px;
				letter-spacing: 0.16em;
				text-transform: uppercase;
				color: var(--mute);
				margin-bottom: 8px;
			}
			.rate .rv {
				font-family: "Archivo", sans-serif;
				font-weight: 700;
				font-size: 26px;
			}

			/* related — full bleed grid */
			.more-h {
				max-width: 1100px;
				margin: 80px auto 0;
				padding: 0 26px;
			}
			.more-h .caps {
				font-size: 12px;
				border-top: 1px solid var(--ink);
				padding-top: 18px;
				display: block;
			}
			/* Single-row horizontal carousel, not a wrapping grid — a fixed
			   card width in a grid either left an awkward gap (few items,
			   wide window) or wrapped to more rows than wanted as the list
			   grew past a single screen's width. A native scroll-snap row
			   sidesteps both: any item count just scrolls, swipes on touch,
			   and never wraps or gaps. No JS needed for the swipe itself. */
			.rgrid {
				display: flex;
				overflow-x: auto;
				scroll-snap-type: x mandatory;
				-webkit-overflow-scrolling: touch;
				scrollbar-width: none;
				border-top: 1px solid var(--ink);
				border-bottom: 1px solid var(--ink);
				margin-top: 22px;
			}
			.rgrid::-webkit-scrollbar {
				display: none;
			}
			.rcard {
				position: relative;
				flex: 0 0 clamp(200px, 30vw, 280px);
				aspect-ratio: 3 / 4;
				scroll-snap-align: start;
				background: var(--img);
				border-right: 1px solid var(--ink);
				overflow: hidden;
				text-decoration: none;
				cursor: pointer;
				display: block;
			}
			/* Locked cards are real <button>s (see RelatedGrid), so they need
			   the usual button reset before they can pass for a .rcard. */
			button.rcard {
				border: none;
				border-right: 1px solid var(--ink);
				font: inherit;
				text-align: left;
				padding: 0;
				margin: 0;
				width: 100%;
			}
			.rcard.locked img,
			.rcard.locked .ph {
				filter: grayscale(1) brightness(0.55);
			}
			.rcard.locked .lock {
				position: absolute;
				top: 14px;
				left: 14px;
				z-index: 2;
				font-size: 10px;
				letter-spacing: 0.16em;
				color: var(--paper);
				background: var(--ink);
				padding: 3px 8px;
			}
			.rcard img {
				position: absolute;
				inset: 0;
				width: 100%;
				height: 100%;
				object-fit: cover;
				display: block;
			}
			.rgrid .rcard:last-child {
				border-right: none;
			}
			.rcard .ph {
				position: absolute;
				inset: 0;
				display: flex;
				align-items: center;
				justify-content: center;
			}
			.rcard .ph span {
				font-family: "Space Mono", monospace;
				font-size: 11px;
				letter-spacing: 0.16em;
				color: var(--mute);
				text-transform: uppercase;
			}
			.rcard .lab {
				position: absolute;
				left: 16px;
				bottom: 16px;
				right: 16px;
			}
			.rcard .cat {
				font-family: "Space Mono", monospace;
				font-size: 10px;
				letter-spacing: 0.18em;
				text-transform: uppercase;
				color: var(--ink);
				background: var(--paper);
				padding: 2px 6px;
				display: inline-block;
				margin-bottom: 8px;
			}
			.rcard .t {
				font-family: "Space Mono", monospace;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.1em;
				font-size: 14px;
				line-height: 1.25;
				color: var(--ink);
			}
			.rcard:hover .ph {
				opacity: 0.7;
			}

			footer.serial-footer {
				border-top: 1px solid var(--ink);
				margin-top: 80px;
				padding: 44px 26px;
			}
			.fbar {
				max-width: 1100px;
				margin: 0 auto;
				display: flex;
				justify-content: space-between;
				align-items: flex-end;
				flex-wrap: wrap;
				gap: 20px;
			}
			.fbar .fl {
				font-family: "Archivo", sans-serif;
				font-weight: 700;
				font-size: 22px;
				letter-spacing: 0.28em;
				text-transform: uppercase;
				text-decoration: none;
				color: var(--ink);
			}
			.fbar .fnav {
				display: flex;
				gap: 26px;
			}
			.fbar .fnav a {
				font-family: "Space Mono", monospace;
				font-size: 11px;
				letter-spacing: 0.16em;
				text-transform: uppercase;
				color: var(--ink);
				text-decoration: none;
			}
			.fmeta {
				max-width: 1100px;
				margin: 26px auto 0;
				display: flex;
				justify-content: space-between;
				flex-wrap: wrap;
				gap: 8px;
				font-family: "Space Mono", monospace;
				font-size: 10px;
				letter-spacing: 0.16em;
				text-transform: uppercase;
				color: var(--mute);
				border-top: 1px solid var(--hair);
				padding-top: 16px;
			}

			@media (max-width: 820px) {
				nav.links {
					display: none;
				}
				.burger {
					display: block;
				}
				.grid3 {
					grid-template-columns: 1fr 1fr;
				}
				/* .rgrid stays a horizontal flex carousel on mobile too —
				   that's the point of the swipe interaction, so no
				   column-stacking override here. .rcard keeps its 3/4
				   portrait ratio at a slightly narrower clamp so ~1.5
				   cards preview on a phone screen, hinting there's more
				   to swipe to. */
				.rcard {
					flex-basis: clamp(168px, 62vw, 240px);
				}
				.rate {
					grid-template-columns: 1fr 1fr !important;
				}
				.hero {
					height: 70vh;
				}
			}
			@media (prefers-reduced-motion: reduce) {
				* {
					scroll-behavior: auto;
				}
			}
		</style>
	</body>
</html>
