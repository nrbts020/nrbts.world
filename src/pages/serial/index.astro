---
// Serial — magazine index/landing.
// The original Serial site is offline; this is a from-scratch recreation
// built as an Astro template (see src/layouts/SerialLayout.astro and
// src/components/serial/*) so new articles are just new pages assembled
// from the same components. Only one article exists so far (the Nikon
// FE2 review) — the other five headlines are real (things Norbert
// actually wants to write) but unwritten, so they're `locked` and gated
// behind Paywall.astro instead of 404ing or linking nowhere. The FE2
// piece is offered there as the free sample.
import SerialLayout from "../../layouts/SerialLayout.astro";
import Nav from "../../components/serial/Nav.astro";
import RelatedGrid from "../../components/serial/RelatedGrid.astro";
import Paywall from "../../components/serial/Paywall.astro";
import Footer from "../../components/serial/Footer.astro";
---

<SerialLayout
	title="Serial — Gear, Film, Culture"
	description="Serial — gear reviews, film notes, and culture. A personal recreation of an offline magazine site."
>
	<Nav />

	<div class="wrap">
		<div class="section masthead" style="padding-top:64px">
			<p class="caps masthead-eyebrow">Gear &middot; Film &middot; Culture</p>
			<h1 class="masthead-title brandf">Serial</h1>
			<p class="masthead-sub">
				A magazine that stopped shipping — recreated here in parts, ported straight from the
				original design system and code.
			</p>
		</div>
	</div>

	<RelatedGrid
		heading="Latest"
		items={[
			{
				href: "/serial/nikon-fe2",
				category: "Review",
				title: "The Nikon FE2 — the unsung hero of Civil War",
				image: { src: "/images/serial/hero-fe2-topplate.jpg", alt: "Close-up of the Nikon FE2 top plate" },
			},
			{
				href: "#",
				category: "Film",
				title: "Squaring the Circle: The Story of Hipgnosis — Reviewed",
				image: { src: "/images/serial/hipgnosis-poster.jpg", alt: "Japanese theatrical poster for Squaring the Circle: The Story of Hipgnosis" },
				locked: true,
			},
			{
				href: "#",
				category: "Music",
				title: "A Short History of DJ Shadow",
				image: { src: "/images/serial/dj-shadow.jpg", alt: "DJ Shadow — Midnight in a Perfect World single artwork" },
				locked: true,
			},
			{
				href: "#",
				category: "Culture",
				title: "Ranking Amsterdam's Cinemas",
				image: { src: "/images/serial/eye-film-museum.jpg", alt: "The EYE Film Museum on the IJ waterfront, Amsterdam, lit at dusk" },
				locked: true,
			},
			{
				href: "/serial/s12-silvia",
				category: "Drive",
				title: "The S12 Silvia — Initial D's Biggest Snub",
				image: { src: "/images/serial/s12-silvia.jpg", alt: "The front fender and wheel of a white Nissan S12 Silvia" },
			},
			{
				href: "#",
				category: "Esports",
				title: "NRG Wins VALORANT Champions 2025",
				image: { src: "/images/serial/nrg-champions.jpg", alt: "An NRG Valorant player celebrating on stage" },
				locked: true,
			},
			{
				href: "#",
				category: "Interview",
				title: "Siebrand — Black Gold, Vinyl & Coffee",
				image: { src: "/images/serial/black-gold-siebrand.jpg", alt: "Siebrand standing outside Black Gold, Vinyl & Coffee in Amsterdam" },
				locked: true,
			},
			{
				href: "#",
				category: "Books",
				title: "Neuromancer Walked So The Matrix Could Run — An Analysis",
				image: { src: "/images/serial/neuromancer-cover.jpg", alt: "Cover of William Gibson's Neuromancer, Ace Science Fiction edition" },
				locked: true,
			},
			{
				href: "#",
				category: "Sports",
				title: "Ma Long and Xu Xin — Two Ends of the Sports Psychology Spectrum",
				image: { src: "/images/serial/malong-xuxin.jpg", alt: "Table tennis players Ma Long and Xu Xin standing together in China national team kits" },
				locked: true,
			},
			{
				href: "/serial/nemo-disco-15",
				category: "Gear",
				title: "The Nemo Disco 15 — Cocoon Mode on the JMT",
				image: { src: "/images/serial/nemo-disco-15.jpg", alt: "The Nemo Disco 15 sleeping bag with its gold Blanket Fold collar open" },
			},
			{
				href: "#",
				category: "Food",
				title: "Noma, Copenhagen — Reviewed",
				image: { src: "/images/serial/noma-copenhagen.jpg", alt: "The wood and brick exterior of Noma restaurant, Copenhagen, surrounded by tall grass" },
				locked: true,
			},
		]}
	/>

	<Footer />

	<Paywall />

	<style>
		.masthead {
			max-width: 760px;
			margin: 0 auto;
			text-align: center;
			padding-bottom: 8px;
		}
		.masthead-eyebrow {
			font-size: 12px;
			color: var(--mute);
			margin-bottom: 18px;
		}
		.masthead-title {
			font-size: clamp(2.6rem, 9vw, 5rem);
			letter-spacing: 0.02em;
			line-height: 1;
			margin-bottom: 20px;
		}
		.masthead-sub {
			color: var(--ink2);
			font-size: 15px;
			line-height: 1.7;
			max-width: 52ch;
			margin: 0 auto;
		}
	</style>
</SerialLayout>
