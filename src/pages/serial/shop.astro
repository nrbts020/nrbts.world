---
// Serial — Shop (concept). Nav/Footer already pointed to "/serial/shop" as
// a real destination once this existed, so it's built the same way the
// rest of the recreation is: honest about being a portfolio piece, not a
// live store — no cart, no checkout, just a handful of imagined merch
// objects that exist because the logo deserved to leave the browser tab.
//
// No photorealistic image-generation tool is available in this
// environment, so the products are hand-drawn flat SVG illustrations in
// Serial's own ink/paper monochrome system instead of product photos —
// which actually fits the "concrete/steel, monochrome-by-intent" design
// language better than a photo would have. The T-Shirt tile spins on a
// CSS rotateY loop (pure illusion — it's still one flat SVG, no second
// "back" frame) to stand in for a 360° product view; pauses on hover and
// respects prefers-reduced-motion.
import SerialLayout from "../../layouts/SerialLayout.astro";
import Nav from "../../components/serial/Nav.astro";
import Footer from "../../components/serial/Footer.astro";

const products = [
	{
		name: "Serial Lighter",
		price: "$8",
		copy: "Black Bic-style flip-top, S mark printed on the panel. Runs out exactly when the article does.",
	},
	{
		name: "Serial Tote",
		price: "$28",
		copy: "Heavy canvas, one size, one mark. Holds a camera body and whatever you didn't plan on buying.",
	},
	{
		name: "Serial Pin",
		price: "$12",
		copy: "Enamel, clipped corner, butterfly clasp. The logo, worth pinning to something.",
	},
	{
		name: "Serial T-Shirt",
		price: "$32",
		copy: "Heavyweight cotton, one clipped corner on the chest. Spins for effect; does not actually rotate in the wash.",
	},
];
---

<SerialLayout title="Shop — Serial" description="Serial merch — a small concept drop, not a live store.">
	<Nav />

	<div class="wrap">
		<div class="section masthead" style="padding-top:64px">
			<p class="caps masthead-eyebrow">Merch &middot; Concept</p>
			<h1 class="masthead-title brandf">Shop</h1>
			<p class="masthead-sub">
				A small concept drop — objects that exist because the logo deserved to leave the browser
				tab. Illustrated, not photographed, and not actually for sale.
			</p>
		</div>
	</div>

	<div class="wrap">
		<div class="shop-grid">
			{
				products.map((product) => (
					<div class="shop-card">
						<div class="shop-art">
							{product.name === "Serial Lighter" && (
								<svg viewBox="0 0 160 320" role="img" aria-label="Illustration of a black lighter with the Serial S mark">
									<rect x="25" y="70" width="110" height="230" rx="16" fill="var(--ink)" />
									<rect x="40" y="25" width="80" height="55" rx="6" fill="var(--mute)" />
									<circle cx="58" cy="40" r="9" fill="var(--img)" />
									<rect x="80" y="32" width="30" height="10" rx="2" fill="var(--paper)" />
									<polygon points="45,140 115,140 115,194.6 99.6,210 45,210" fill="var(--paper)" />
									<text x="80" y="185" text-anchor="middle" font-family="Archivo, sans-serif" font-weight="700" font-size="34" fill="var(--ink)">S</text>
									<text x="80" y="238" text-anchor="middle" font-family="Space Mono, monospace" font-size="11" letter-spacing="3" fill="var(--paper)">SERIAL</text>
								</svg>
							)}
							{product.name === "Serial Tote" && (
								<svg viewBox="0 0 260 300" role="img" aria-label="Illustration of a canvas tote bag with the Serial S mark">
									<path d="M80,62 C80,18 100,8 130,8 C160,8 180,18 180,62" fill="none" stroke="var(--ink)" stroke-width="4" />
									<rect x="30" y="60" width="200" height="220" fill="var(--form)" stroke="var(--ink)" stroke-width="3" />
									<polygon points="95,130 165,130 165,184.6 149.6,200 95,200" fill="var(--ink)" />
									<text x="130" y="175" text-anchor="middle" font-family="Archivo, sans-serif" font-weight="700" font-size="34" fill="var(--paper)">S</text>
									<text x="130" y="228" text-anchor="middle" font-family="Space Mono, monospace" font-size="12" letter-spacing="4" fill="var(--ink)">SERIAL</text>
								</svg>
							)}
							{product.name === "Serial Pin" && (
								<svg viewBox="0 0 200 220" role="img" aria-label="Illustration of an enamel pin with the Serial S mark">
									<polygon points="30,20 170,20 170,129.2 145.6,160 30,160" fill="var(--ink)" />
									<text x="100" y="108" text-anchor="middle" font-family="Archivo, sans-serif" font-weight="700" font-size="56" fill="var(--paper)">S</text>
									<rect x="92" y="165" width="16" height="22" fill="var(--mute)" />
									<circle cx="100" cy="192" r="9" fill="var(--img)" />
								</svg>
							)}
							{product.name === "Serial T-Shirt" && (
								<div class="spin-stage">
									<svg class="spin-el" viewBox="0 0 240 280" role="img" aria-label="Illustration of a t-shirt with the Serial S mark, spinning in place">
										<path d="M60,40 L95,15 Q120,42 145,15 L180,40 L165,78 L165,260 L75,260 L75,78 Z" fill="var(--form)" stroke="var(--ink)" stroke-width="4" stroke-linejoin="round" />
										<polygon points="90,112 150,112 150,166.6 134.6,182 90,182" fill="var(--ink)" />
										<text x="120" y="157" text-anchor="middle" font-family="Archivo, sans-serif" font-weight="700" font-size="34" fill="var(--paper)">S</text>
										<text x="120" y="222" text-anchor="middle" font-family="Space Mono, monospace" font-size="10" letter-spacing="3" fill="var(--ink2)">SERIAL</text>
									</svg>
								</div>
							)}
						</div>
						<div class="shop-info">
							<div class="shop-info-top">
								<span class="shop-name">{product.name}</span>
								<span class="shop-price mono">{product.price}</span>
							</div>
							<p class="shop-copy">{product.copy}</p>
							<span class="shop-badge caps">Concept &middot; not for sale</span>
						</div>
					</div>
				))
			}
		</div>
	</div>

	<Footer />

	<style>
		.masthead {
			max-width: 760px;
			margin: 0 auto;
			text-align: center;
			padding-bottom: 8px;
		}
		.masthead-eyebrow {
			font-size: 12px;
			color: var(--mute);
			margin-bottom: 18px;
		}
		.masthead-title {
			font-size: clamp(2.6rem, 9vw, 5rem);
			letter-spacing: 0.02em;
			line-height: 1;
			margin-bottom: 20px;
		}
		.masthead-sub {
			color: var(--ink2);
			font-size: 15px;
			line-height: 1.7;
			max-width: 52ch;
			margin: 0 auto;
		}
		.shop-grid {
			display: grid;
			grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
			gap: 0;
			border-top: 1px solid var(--ink);
			border-left: 1px solid var(--ink);
			margin: 64px 0 80px;
		}
		.shop-card {
			border-right: 1px solid var(--ink);
			border-bottom: 1px solid var(--ink);
			display: flex;
			flex-direction: column;
		}
		.shop-art {
			background: var(--form);
			aspect-ratio: 4 / 5;
			display: flex;
			align-items: center;
			justify-content: center;
			padding: 32px;
		}
		.shop-art svg {
			width: 100%;
			height: 100%;
		}
		.spin-stage {
			width: 100%;
			height: 100%;
			perspective: 900px;
			display: flex;
			align-items: center;
			justify-content: center;
		}
		.spin-el {
			width: 100%;
			height: 100%;
			animation: spin-y 5.5s linear infinite;
			transform-style: preserve-3d;
			will-change: transform;
		}
		.shop-art:hover .spin-el {
			animation-play-state: paused;
		}
		@keyframes spin-y {
			from {
				transform: rotateY(0deg);
			}
			to {
				transform: rotateY(360deg);
			}
		}
		@media (prefers-reduced-motion: reduce) {
			.spin-el {
				animation: none;
			}
		}
		.shop-info {
			padding: 20px 22px 24px;
		}
		.shop-info-top {
			display: flex;
			justify-content: space-between;
			align-items: baseline;
			margin-bottom: 10px;
		}
		.shop-name {
			font-family: "Archivo", sans-serif;
			font-weight: 700;
			font-size: 16px;
			letter-spacing: 0.01em;
		}
		.shop-price {
			font-size: 13px;
			color: var(--mute);
		}
		.shop-copy {
			font-size: 13.5px;
			line-height: 1.6;
			color: var(--ink2);
			margin-bottom: 14px;
		}
		.shop-badge {
			display: inline-block;
			font-size: 10px;
			letter-spacing: 0.14em;
			color: var(--mute);
			border: 1px solid var(--mute);
			padding: 3px 8px;
		}
	</style>
</SerialLayout>
