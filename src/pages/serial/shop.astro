---
// Serial — Shop (concept). Nav/Footer already pointed to "/serial/shop" as
// a real destination once this existed, so it's built the same way the
// rest of the recreation is: honest about being a portfolio piece, not a
// live store — no cart, no checkout, just a handful of imagined merch
// objects that exist because the logo deserved to leave the browser tab.
//
// User-sourced real product photography replaced the earlier hand-drawn
// SVG placeholders once the assets existed (dropped into _incoming as
// serial_cap.png, serial_lighter.png, serial_computerkind.png, and an
// eic_front/eic_back pair for the longsleeve — "eic" being the joke
// printed across its back, EDITOR IN CHIEF). The longsleeve also came
// with a short looping clip (serial_longsleeve_animated.mp4, re-encoded
// down to ~160kb/480px wide for mobile) used in place of a static photo;
// autoplay is gated behind a prefers-reduced-motion check below instead
// of the CSS-only approach the old spinning-T-shirt SVG used, since a
// real <video> needs its play() call suppressed in JS, not just its
// animation. Tote and Pin never got photographed and are dropped rather
// than left as the odd illustrated-out SVGs in an otherwise-photographed
// grid.
import SerialLayout from "../../layouts/SerialLayout.astro";
import Nav from "../../components/serial/Nav.astro";
import Footer from "../../components/serial/Footer.astro";

const products = [
	{
		name: "Serial Longsleeve",
		price: "$58",
		copy: "Heavyweight cotton, small serial mark on the chest, EDITOR IN CHIEF stamped across the back — a title nobody assigned.",
	},
	{
		name: "Serial T-Shirt",
		price: "$32",
		copy: "Washed black cotton, COMPUTER KIND printed dead center. For anyone the algorithm already knows too well.",
	},
	{
		name: "Serial Cap",
		price: "$24",
		copy: "Low-profile six-panel, serial printed in white across the front. Pulls the bill down over whatever you were about to overthink.",
	},
	{
		name: "Serial Lighter",
		price: "$8",
		copy: "Black flip-top, S mark printed on the panel. Runs out exactly when the article does.",
	},
];
---

<SerialLayout title="Shop — Serial" description="Serial merch — a small concept drop, not a live store.">
	<Nav />

	<div class="wrap">
		<div class="section masthead" style="padding-top:64px">
			<p class="caps masthead-eyebrow">Merch &middot; Concept</p>
			<h1 class="masthead-title brandf">Shop</h1>
			<p class="masthead-sub">
				A small concept drop — objects that exist because the logo deserved to leave the browser
				tab. Real samples, not a live store — nothing here is actually for sale.
			</p>
		</div>
	</div>

	<div class="wrap">
		<div class="shop-grid">
			{
				products.map((product) => (
					<div class="shop-card">
						<div class="shop-art">
							{product.name === "Serial Longsleeve" && (
								<video
									class="shop-video"
									data-autoplay
									poster="/images/serial/shop-longsleeve-front.jpg"
									src="/videos/serial/shop-longsleeve.mp4"
									loop
									muted
									playsinline
									aria-label="Looping clip of a model wearing the white Serial longsleeve, EDITOR IN CHIEF printed across the back"
								/>
							)}
							{product.name === "Serial T-Shirt" && (
								<img
									src="/images/serial/shop-tshirt.jpg"
									alt="A model wearing the black Serial T-Shirt with COMPUTER KIND printed on the chest"
									loading="lazy"
								/>
							)}
							{product.name === "Serial Cap" && (
								<img
									src="/images/serial/shop-cap.jpg"
									alt="A model wearing the black Serial cap with the serial wordmark on the front panel"
									loading="lazy"
								/>
							)}
							{product.name === "Serial Lighter" && (
								<img src="/images/serial/shop-lighter.jpg" alt="A black lighter printed with the serial wordmark" loading="lazy" />
							)}
						</div>
						<div class="shop-info">
							<div class="shop-info-top">
								<span class="shop-name">{product.name}</span>
								<span class="shop-price mono">{product.price}</span>
							</div>
							<p class="shop-copy">{product.copy}</p>
							<span class="shop-badge caps">Concept &middot; not for sale</span>
						</div>
					</div>
				))
			}
		</div>
	</div>

	<Footer />

	<script>
		// Real <video> autoplay isn't stoppable with CSS alone the way the old
		// spinning-SVG loop was — gate the actual play() call on the same
		// prefers-reduced-motion check instead, and pause on hover to match
		// the old hover-pause behaviour of the illustrated tiles.
		const vid = document.querySelector<HTMLVideoElement>(".shop-video");
		if (vid) {
			const reduce = matchMedia("(prefers-reduced-motion: reduce)").matches;
			if (!reduce) {
				vid.play().catch(() => {});
				vid.addEventListener("mouseenter", () => vid.pause());
				vid.addEventListener("mouseleave", () => vid.play().catch(() => {}));
			}
		}
	</script>

	<style>
		.masthead {
			max-width: 760px;
			margin: 0 auto;
			text-align: center;
			padding-bottom: 8px;
		}
		.masthead-eyebrow {
			font-size: 12px;
			color: var(--mute);
			margin-bottom: 18px;
		}
		.masthead-title {
			font-size: clamp(2.6rem, 9vw, 5rem);
			letter-spacing: 0.02em;
			line-height: 1;
			margin-bottom: 20px;
		}
		.masthead-sub {
			color: var(--ink2);
			font-size: 15px;
			line-height: 1.7;
			max-width: 52ch;
			margin: 0 auto;
		}
		.shop-grid {
			display: grid;
			grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
			gap: 0;
			border-top: 1px solid var(--ink);
			border-left: 1px solid var(--ink);
			margin: 64px 0 80px;
		}
		.shop-card {
			border-right: 1px solid var(--ink);
			border-bottom: 1px solid var(--ink);
			display: flex;
			flex-direction: column;
		}
		.shop-art {
			position: relative;
			background: var(--img);
			aspect-ratio: 4 / 5;
			overflow: hidden;
		}
		.shop-art img,
		.shop-art video {
			position: absolute;
			inset: 0;
			width: 100%;
			height: 100%;
			object-fit: cover;
			display: block;
		}
		.shop-info {
			padding: 20px 22px 24px;
		}
		.shop-info-top {
			display: flex;
			justify-content: space-between;
			align-items: baseline;
			margin-bottom: 10px;
		}
		.shop-name {
			font-family: "Archivo", sans-serif;
			font-weight: 700;
			font-size: 16px;
			letter-spacing: 0.01em;
		}
		.shop-price {
			font-size: 13px;
			color: var(--mute);
		}
		.shop-copy {
			font-size: 13.5px;
			line-height: 1.6;
			color: var(--ink2);
			margin-bottom: 14px;
		}
		.shop-badge {
			display: inline-block;
			font-size: 10px;
			letter-spacing: 0.14em;
			color: var(--mute);
			border: 1px solid var(--mute);
			padding: 3px 8px;
		}
	</style>
</SerialLayout>
