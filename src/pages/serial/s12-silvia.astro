			{ label: "Chassis", value: "FR" },
			{ label: "Obscurity", value: "High" },
			{ label: "Verdict", value: "Slept on" },
		]}
	/>

	<ImageGrid
		variant="wide"
		tiles={[
			{
				aspect: "16 / 6",
				image: {
					src: "/images/serial/s12-lakeside.jpg",
