			:root {
				--bg: #05070a;
				--teal: #0a9d9d;
				--teal-bright: #7fe0e6;
				--purple: #6a4fb6;
				--text: #e6ecf0;
				--text-dim: rgba(230, 236, 240, 0.7);
				--sans: "Sora", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
				--mono: ui-monospace, "SF Mono", "Cascadia Code", "Roboto Mono", Consolas, monospace;
				--display: "Chakra Petch", var(--sans);
				--panel-bg: rgba(247, 250, 252, 0.94);
				--panel-border: rgba(140, 160, 175, 0.4);
				--panel-text: #14181d;
				--panel-text-dim: #3d444b;
				--cut: 22px;
				--nav-bg: rgba(214, 52, 34, 0.34);
				--nav-border: rgba(255, 255, 255, 0.2);
				--nav-text: rgba(255, 241, 236, 0.85);
			}

			html,
			body {
				margin: 0;
				padding: 0;
				background: var(--bg);
				color: var(--text);
				font-family: var(--sans);
			}
			.mono {
				font-family: var(--mono);
			}

			.site-nav {
				position: fixed;
				top: max(14px, env(safe-area-inset-top));
				left: max(14px, env(safe-area-inset-left));
				display: flex;
				gap: 4px;
				padding: 6px;
				background: var(--nav-bg);
				border: 1px solid var(--nav-border);
				border-radius: 2px;
				backdrop-filter: blur(6px);
				-webkit-backdrop-filter: blur(6px);
				z-index: 10;
			}
			.site-nav a {
				color: var(--nav-text);
				text-decoration: none;
				font: 500 12px/1 var(--mono);
				letter-spacing: 0.02em;
				padding: 8px 12px;
				touch-action: manipulation;
			}
			.site-nav a:hover,
			.site-nav a:focus-visible {
				color: #fff;
				background: rgba(255, 255, 255, 0.16);
			}

			.content {
				max-width: 760px;
				margin: 0 auto;
				padding: 96px max(24px, env(safe-area-inset-left)) 48px;
			}

			.writing-hero {
				margin-bottom: 40px;
			}
			.eyebrow {
				color: var(--teal-bright);
				letter-spacing: 0.16em;
				font-size: 12px;
				margin: 0 0 12px;
			}
			.writing-hero h1 {
				font-family: var(--display);
				font-weight: 700;
				font-size: clamp(1.9rem, 5.2vw, 2.8rem);
				line-height: 1.1;
				margin: 0 0 10px;
			}
			.hero-sub {
				color: var(--text-dim);
				margin: 0;
			}

			.essays {
				display: flex;
				flex-direction: column;
				gap: 28px;
			}

			/* Same cut-corner light panel language as index.astro's project
			   cards/panels, so this page still reads as nrbts.world even
			   without the scene behind it. */
			.essay.panel-body {
				background: var(--panel-bg);
				color: var(--panel-text);
				border: 1px solid var(--panel-border);
				clip-path: polygon(0 0, calc(100% - var(--cut)) 0, 100% var(--cut), 100% 100%, 0 100%);
				padding: 36px;
			}
			.essay-meta {
				color: var(--teal);
				font-size: 11px;
				letter-spacing: 0.06em;
				margin: 0 0 8px;
			}
			.essay h2 {
				font-family: var(--display);
				font-weight: 600;
				font-size: clamp(1.3rem, 3vw, 1.7rem);
				margin: 0 0 20px;
			}
			.essay-body p {
				color: var(--panel-text-dim);
				line-height: 1.7;
				max-width: 66ch;
				margin: 0;
			}
			.essay-body p + p {
				margin-top: 16px;
			}

			.site-footer {
				text-align: center;
				margin-top: 56px;
			}
			.site-footer a {
				color: var(--teal-bright);
				text-decoration: none;
				font-size: 13px;
			}
			.site-footer a:hover {
				text-decoration: underline;
			}

			@media (max-width: 640px) {
				.content {
					padding: 88px 18px 40px;
				}
				.essay.panel-body {
					padding: 22px;
				}
			}
		</style>
