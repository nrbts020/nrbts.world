		<script>
			import { initScene } from '../scene/scene';
			// Read-only reuse of sky.ts's pure day-factor math (day-mode-handoff
			// item 1/2) — does NOT touch scene.ts, city/haze/moon geometry, or
			// night rendering. This only drives a CSS attribute on <html> so the
			// content-layer overlays below know whether to show themselves.
			import { dayFactor, hoursOf } from '../scene/sky';

			const canvas = document.getElementById('scene-canvas') as HTMLCanvasElement;
			if (canvas) {
				const handle = initScene(canvas);

				// Mirrors scene.ts's own override dates (day=13:00, night=01:00)
				// so the CSS overlays agree with what's actually on screen.
				function effectiveDateFor(mode: 'live' | 'day' | 'night'): Date {
					if (mode === 'live') return new Date();
					const d = new Date();
					d.setHours(mode === 'day' ? 13 : 1, 0, 0, 0);
					return d;
				}
				function applySkyAttr(mode: 'live' | 'day' | 'night') {
					const factor = dayFactor(hoursOf(effectiveDateFor(mode)));
					document.documentElement.dataset.sky = factor >= 0.5 ? 'day' : 'night';
				}

				let currentMode: 'live' | 'day' | 'night' = 'live';
				applySkyAttr(currentMode);
				// Re-check periodically so "Live" mode still crosses over at real
				// dawn/dusk during a long visit, without any per-frame cost.
				setInterval(() => applySkyAttr(currentMode), 60000);

				const buttons = document.querySelectorAll<HTMLButtonElement>('.time-toggle button');
				buttons.forEach((button) => {
					button.addEventListener('click', () => {
						const mode = button.dataset.mode as 'live' | 'day' | 'night';
						handle.setTimeOverride(mode);
						currentMode = mode;
						applySkyAttr(mode);
						buttons.forEach((b) => b.classList.toggle('active', b === button));
					});
				});
			}

			// Independent day-mode fog drift (handoff v2 §2). The buildings
			// already parallax with the mouse inside the Three.js scene — that
			// stays untouched. This gives the CSS fog layer its OWN slower,
			// eased, inverted drift so the two layers read as distinct depths
			// rather than one clumsy layer moving together. The easing is the
			// CSS `transition: transform` on .fog-layer; here we just set the
			// target transform. Gated to fine pointers with motion allowed, so
			// touch devices (and reduced-motion users) leave the fog static —
			// no per-frame or per-move cost on mobile, per the perf constraint.
			const fog = document.querySelector<HTMLElement>('.fog-layer');
			const canDrift =
				matchMedia('(pointer: fine)').matches &&
				!matchMedia('(prefers-reduced-motion: reduce)').matches;
			if (fog && canDrift) {
				const FOG_RANGE = 48; // px of max drift at the screen edges
				let raf = 0;
				window.addEventListener(
					'pointermove',
					(e) => {
						if (raf) return; // coalesce to one update per frame
						raf = requestAnimationFrame(() => {
							raf = 0;
							const nx = e.clientX / window.innerWidth - 0.5; // -0.5..0.5
							const ny = e.clientY / window.innerHeight - 0.5;
							// Inverted from the cursor (reads more like atmosphere
							// than a skyline rigidly tracking the mouse); vertical
							// drift is damped so the bank mostly slides sideways.
							fog.style.transform = `translate(${-nx * FOG_RANGE}px, ${-ny * FOG_RANGE * 0.5}px)`;
						});
					},
					{ passive: true }
				);
			}

			// Lightweight YouTube "click to load" facade: shows just a static
			// thumbnail + play glyph until clicked, so visiting the page never
			// pulls in YouTube's embed JS/iframe cost unless the visitor
			// actually presses play — mobile-performance-conscious, same
			// spirit as the self-hosted Ekin video's preload="none".
			document.querySelectorAll<HTMLElement>('.proj-embed').forEach((el) => {
				const activate = () => {
					const id = el.dataset.ytId;
					if (!id) return;
					const iframe = document.createElement('iframe');
					iframe.src = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1`;
					iframe.setAttribute(
						'allow',
						'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture'
					);
					iframe.setAttribute('allowfullscreen', '');
					iframe.style.cssText = 'width:100%;height:100%;border:0;display:block;';
					el.replaceChildren(iframe);
					el.removeAttribute('role');
					el.removeAttribute('tabindex');
				};
				el.addEventListener('click', activate);
				el.addEventListener('keydown', (e) => {
					if (e.key === 'Enter' || e.key === ' ') {
						e.preventDefault();
						activate();
					}
				});
			});
		</script>

		<style>
			:root {
				--bg: #05070a;
				--teal: #0a9d9d;
				--teal-bright: #7fe0e6;
				--purple: #6a4fb6;
				--text: #e6ecf0;
				--text-dim: rgba(230, 236, 240, 0.7);
				--sans: "Sora", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
				--mono: ui-monospace, "SF Mono", "Cascadia Code", "Roboto Mono", Consolas, monospace;
				--display: "Chakra Petch", var(--sans);

				/* Crisp near-white HUD-panel surface (map-screen reference pass —
				   the earlier blue-tinted glass read too soft/dreamy next to the
				   reference's clean opaque white readouts). Cooler, more opaque,
				   with a thin cool-grey hairline border instead of a soft white
				   one — used for any block of sustained-reading content (About,
				   project cards, the resume card, Contact). Still paired with a
				   backdrop blur so the scene shows through softly at the edges. */
				--panel-bg: rgba(247, 250, 252, 0.94);
				--panel-border: rgba(140, 160, 175, 0.4);
				--panel-text: #14181d;
				--panel-text-dim: #3d444b;
				--cut: 22px;

				/* Small tag chips sit directly on the scene, not inside a
				   blurred panel — same crisp surface as --panel-bg (cheaper on
				   mobile than blurring ~20 small chips individually, since it's
				   already opaque enough to skip backdrop-filter). */
				--chip-bg: rgba(247, 250, 252, 0.94);

				/* Nav + time-toggle chrome: translucent warm red/orange glass,
				   a deliberate callback to Mirror's Edge's red UI/wayfinding
				   accent, distinct from the teal/purple used for content. */
				--nav-bg: rgba(214, 52, 34, 0.34);
				--nav-border: rgba(255, 255, 255, 0.2);
				--nav-text: rgba(255, 241, 236, 0.85);
				--nav-active-bg: rgba(255, 255, 255, 0.88);
				--nav-active-text: #c81e1e;

				/* Day-mode legibility pass (nrbts-daymode-handoff.md item 3):
				   the one unified "glass" card material for panel-body/project-
				   card, replacing what used to be slightly different treatments
				   on each. Applies regardless of day/night — it's a content-
				   layer material choice, not a scene effect — so it's separate
				   from the --panel-* variables above, which other elements
				   (resume-link, contact list, dividers) still use unchanged. */
				--glass-bg: rgba(248, 251, 254, 0.84);
				--glass-border: rgba(255, 255, 255, 0.72);
				--glass-shadow: 0 22px 50px -26px rgba(8, 24, 48, 0.6);
				--glass-title: #1a2430;
				--glass-meta: #159e8b;
				--glass-body: #4a5560;
			}

			html {
				scroll-behavior: smooth;
			}
			html, body {
				margin: 0;
				padding: 0;
				background: var(--bg);
				color: var(--text);
				font-family: var(--sans);
			}
			.mono {
				font-family: var(--mono);
			}

			/* Scene stays pinned full-viewport behind everything as the page
			   scrolls through content — see Stage 10 note above. */
			#scene-canvas {
				position: fixed;
				inset: 0;
				display: block;
				width: 100vw;
				height: 100vh;
				z-index: 0;
			}

			/* Small HUD-style controls floating directly on the scene keep
			   sharp/minimal corners (not full pills) to match the angular
			   direction, without going as far as the faceted card cut used on
			   larger content surfaces below. */
			.site-nav {
				position: fixed;
				top: max(14px, env(safe-area-inset-top));
				left: max(14px, env(safe-area-inset-left));
				display: flex;
				gap: 4px;
				padding: 6px;
				background: var(--nav-bg);
				border: 1px solid var(--nav-border);
				border-radius: 2px;
				backdrop-filter: blur(6px);
				-webkit-backdrop-filter: blur(6px);
				z-index: 10;
			}
			.site-nav a {
				color: var(--nav-text);
				text-decoration: none;
				font: 500 12px/1 var(--mono);
				letter-spacing: 0.02em;
				padding: 8px 12px;
				touch-action: manipulation;
			}
			.site-nav a:hover,
			.site-nav a:focus-visible {
				color: #fff;
				background: rgba(255, 255, 255, 0.16);
			}

			.time-toggle {
				position: fixed;
				right: max(14px, env(safe-area-inset-right));
				bottom: max(14px, env(safe-area-inset-bottom));
				display: flex;
				gap: 2px;
				padding: 3px;
				background: var(--nav-bg);
				border: 1px solid var(--nav-border);
				border-radius: 2px;
				backdrop-filter: blur(6px);
				-webkit-backdrop-filter: blur(6px);
				z-index: 10;
			}
			.time-toggle button {
				appearance: none;
				border: none;
				background: transparent;
				color: var(--nav-text);
				font: 500 12px/1 var(--sans);
				letter-spacing: 0.02em;
				padding: 10px 14px;
				cursor: pointer;
				touch-action: manipulation;
			}
			.time-toggle button.active {
				background: var(--nav-active-bg);
				color: var(--nav-active-text);
			}
			.time-toggle button:hover {
				color: #fff;
			}

			/* Day-mode haze (handoff v2): the fog layer sits between the
			   skyline canvas (z 0) and the content (z 2). Fixed, so it stays
			   with the fixed scene canvas as the page scrolls. Overscan inset
			   (-60px) gives the drift room without exposing hard edges.
			   Day-mode only — opacity 0 at night, so it's invisible and its
			   blurred puffs cost nothing when html[data-sky] isn't "day". */
			.fog-layer {
				position: fixed;
				inset: -60px;
				z-index: 1;
				pointer-events: none;
				opacity: 0;
				transition: opacity 0.6s ease, transform 0.5s ease-out;
				will-change: transform;
			}
			html[data-sky="day"] .fog-layer {
				opacity: 1;
			}
			/* Each puff is a soft, flattened radial white blob; the per-puff
			   size / position / opacity / blur are set inline in the markup so
			   the bank reads as scattered depth rather than one flat pane. */
			.fog-puff {
				position: absolute;
				border-radius: 50%;
				background: radial-gradient(closest-side, rgba(255, 255, 255, 0.9) 0%, rgba(255, 255, 255, 0.5) 42%, rgba(255, 255, 255, 0) 78%);
				pointer-events: none;
			}
			/* Thin the bank on small screens (perf): drop the higher, wispier
			   accents and keep just the base-level fog. Mobile also has no
			   pointer drift, so the layer stays fully static there. */
			@media (max-width: 640px) {
				.fog-puff--hi {
					display: none;
				}
			}

			/* Autonomous cloud drift: the whole puff bank slides slowly
			   sideways on its own so the haze reads as moving even with the
			   cursor still (and on touch, where the pointer drift below is
			   off). This is an inner wrapper so it composes with .fog-layer's
			   own pointer-driven transform — parent = mouse response, child =
			   ambient drift. Gated to day mode (no work when the fog is
			   invisible at night) and to motion-OK users. The +/-38px sweep
			   stays within .fog-layer's -60px overscan so no hard edge shows.
			   Tune the duration (lower = faster clouds). */
			.fog-drift {
				position: absolute;
				inset: 0;
				will-change: transform;
			}
			html[data-sky="day"] .fog-drift {
				animation: fogDrift 19s ease-in-out infinite alternate;
			}
			@keyframes fogDrift {
				from { transform: translateX(-38px); }
				to { transform: translateX(38px); }
			}
			@media (prefers-reduced-motion: reduce) {
				html[data-sky="day"] .fog-drift { animation: none; }
			}

			/* Content sits above the fixed canvas in normal document flow — this
			   is what actually gives the page scrollable height. Bumped above
			   the fog layer (z-index 1) so the fog sits between skyline and
			   content. */
			.content {
				position: relative;
				z-index: 2;
			}

			.hero {
				position: relative; /* anchors .scroll-cue to this 100vh block, not the whole page */
				min-height: 100vh;
				display: flex;
				flex-direction: column;
				align-items: flex-start;
				justify-content: center;
				gap: 18px;
				padding: 24px max(24px, env(safe-area-inset-left));
				max-width: 780px;
			}
			/* The v1 dark hero scrim was removed here (handoff v2) — the fog
			   layer above now supplies day-mode contrast via pale atmosphere
			   rather than an opaque dark wash. Headline gets a soft day-mode
			   text-shadow further down instead. */
			.eyebrow {
				position: relative;
				color: var(--teal-bright);
				letter-spacing: 0.16em;
				font-size: 12px;
				margin: 0;
			}
			/* A touch brighter over the day fog than the night-tuned
			   --teal-bright reads as. */
			html[data-sky="day"] .eyebrow {
				color: #8fecdd;
			}
			.capability-stack {
				position: relative; /* sits above the fixed fog layer behind it */
				margin: 0;
				display: flex;
				flex-direction: column;
				gap: 2px;
			}
			.capability-stack span {
				font-family: var(--display);
				font-weight: 700;
				font-size: clamp(1.9rem, 6.4vw, 3.6rem);
				line-height: 1.05;
				letter-spacing: 0.01em;
			}
			.capability-stack .accent {
				color: var(--teal-bright);
			}
			/* Day-mode headline contrast (handoff v2 §1): the fog behind the
			   text pales the backdrop; a soft dark halo then lifts the light
			   headline off it, no full-layer dark wash needed. Night keeps the
			   plain headline — already high-contrast on the dark sky. */
			html[data-sky="day"] .capability-stack span {
				text-shadow: 0 2px 18px rgba(18, 34, 52, 0.3);
			}
			/* Sits in the open sky between the fixed nav and the title line
			   (moved up from the bottom per feedback — down at the bottom it
			   blended into the city skyline silhouette; up here it reads
			   against open sky in both day and night). Positioned
			   independently of the vertically-centered capability-stack text
			   so it holds a fixed spot regardless of how much room that text
			   takes up. */
			.scroll-cue {
				position: absolute;
				left: max(24px, env(safe-area-inset-left));
				top: calc(max(14px, env(safe-area-inset-top)) + 64px);
				display: flex;
				align-items: center;
				gap: 10px;
				text-decoration: none;
			}
			.scroll-cue-glyph {
				display: block;
				width: 26px;
				height: 42px;
				border: 1px solid rgba(255, 255, 255, 0.35);
				position: relative;
				flex-shrink: 0;
			}
			.scroll-cue-glyph span {
				position: absolute;
				left: 50%;
				top: 8px;
				width: 4px;
				height: 8px;
				background: var(--teal-bright);
				transform: translateX(-50%);
				animation: scrollCue 1.6s ease-in-out infinite;
			}
			.scroll-cue-label {
				color: rgba(255, 255, 255, 0.65);
				font-size: 11px;
				letter-spacing: 0.14em;
			}
			@keyframes scrollCue {
				0% { opacity: 1; top: 8px; }
				100% { opacity: 0; top: 22px; }
			}

			.panel {
				padding: 72px max(24px, env(safe-area-inset-left));
				max-width: 960px;
				margin: 0 auto;
			}
			.panel--wide {
				max-width: 1120px;
			}
			.panel h2 {
				font-family: var(--display);
				font-weight: 700;
				font-size: clamp(1.5rem, 3.6vw, 2.1rem);
				margin: 0 0 28px;
			}
			.prompt {
				color: var(--teal);
				font-family: var(--mono);
				margin-right: 4px;
			}
			/* Map-screen reference pass: a small accent bar + a colored-to-
			   transparent underline segment ahead of every subsection label,
			   echoing the tab-and-keyline treatment before headers like
			   "TRIUMVIRATE DRIVE" in the reference — reads consistently
			   whether the label sits directly on the scene or inside a light
			   panel, since it's a solid/gradient teal rather than a neutral
			   hairline that would vanish on a light background. */
			.group-label {
				display: flex;
				align-items: center;
				gap: 8px;
				font-size: 12px;
				letter-spacing: 0.1em;
				color: var(--teal-bright);
				margin: 40px 0 14px;
				padding-bottom: 10px;
				background-image: linear-gradient(to right, var(--teal) 46px, transparent 46px);
				background-repeat: no-repeat;
				background-position: 0 100%;
				background-size: 100% 1px;
			}
			.group-label::before {
				content: "";
				display: block;
				width: 4px;
				height: 14px;
				background: var(--teal);
				flex-shrink: 0;
			}
			.panel > .group-label:first-of-type,
			.panel-body > .group-label:first-child {
				margin-top: 0;
			}

			/* Translucent, angular content surfaces — a cut top-right corner
			   instead of border-radius is the deliberate "not rounded, not a
			   startup card" detail requested; the light-blue translucent fill
			   plus a backdrop blur lets the scene show through softly while
			   keeping text legible whether it's a bright day sky or a dark
			   neon night behind it. */
			/* Day-mode legibility pass (item 3): one unified glass material —
			   see --glass-* in :root — replacing what used to be a slightly
			   different treatment here than on .project-card below. Applies
			   day and night alike; it's a material choice, not a scene
			   effect, so --panel-* stays untouched for the elements
			   (resume-link, contact list, dividers) that still key off it. */
			.panel-body {
				background: var(--glass-bg);
				color: var(--glass-title);
				border: 1px solid var(--glass-border);
				clip-path: polygon(0 0, calc(100% - var(--cut)) 0, 100% var(--cut), 100% 100%, 0 100%);
				padding: 32px;
				backdrop-filter: blur(10px);
				-webkit-backdrop-filter: blur(10px);
				box-shadow: var(--glass-shadow);
			}
			.prose p {
				color: var(--glass-body);
				line-height: 1.65;
				max-width: 68ch;
			}
			.prose p + p {
				margin-top: 16px;
			}

			/* align-items:start overrides grid's default stretch — without
			   it, every card in a row is forced to match the tallest
			   sibling's height (e.g. GGP's status badge + caption, or
			   Uncancel's "View ->" link), leaving visible blank space below
			   the photo on shorter cards like Skate Slow or the adidas FTW
			   wall that don't have that extra line. Cards now size to their
			   own content; row bottoms won't align perfectly, but no more
			   dead space inside any single card. */
			.project-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
				gap: 18px;
				align-items: start;
			}
			.project-card {
				background: var(--glass-bg);
				color: var(--glass-title);
				border: 1px solid var(--glass-border);
				clip-path: polygon(0 0, calc(100% - var(--cut)) 0, 100% var(--cut), 100% 100%, 0 100%);
				padding: 20px;
				backdrop-filter: blur(10px);
				-webkit-backdrop-filter: blur(10px);
				box-shadow: var(--glass-shadow);
			}
			.project-card h3 {
				margin: 0 0 6px;
				font-family: var(--display);
				font-weight: 600;
				font-size: 1.05rem;
			}
			/* Small marker glyph ahead of each project title, echoing the
			   map-screen reference's icon-before-list-item language (quest
			   diamonds, collectible stars) — a CSS ::before so no markup
			   changes were needed across all ten project cards. */
			.project-card h3::before {
				content: "";
				display: inline-block;
				width: 6px;
				height: 6px;
				margin-right: 8px;
				background: var(--teal);
				vertical-align: middle;
			}
			.proj-meta {
				color: var(--glass-meta);
				font-size: 11px;
				letter-spacing: 0.04em;
				margin: 0 0 10px;
			}
			.project-card p:not(.proj-meta) {
				color: var(--glass-body);
				margin: 0;
				font-size: 0.92rem;
				line-height: 1.5;
			}
			.proj-link {
				display: inline-block;
				margin-top: 10px;
				color: var(--teal);
				text-decoration: none;
				font-size: 12px;
			}
			.proj-link:hover {
				color: var(--teal-bright);
				text-decoration: underline;
			}
			/* Small dim caption under a .proj-frame image where the card needs
			   an attribution/context line that isn't the role/year metadata
			   already handled by .proj-meta (e.g. crediting who wrote a note
			   or shot a photo used as evidence rather than as the work itself). */
			.proj-caption {
				margin-top: 8px !important;
				color: var(--panel-text-dim);
				font-size: 11px !important;
				letter-spacing: 0.03em;
			}
			/* NDA/placeholder badge for case studies whose imagery can't be
			   shown yet — a small "classified" tag rather than an empty or
			   apologetic-looking card, in keeping with the map-screen HUD
			   language elsewhere on the page. */
			.proj-status {
				display: inline-block;
				margin-top: 10px !important;
				padding: 5px 10px;
				background: rgba(10, 157, 157, 0.1);
				border: 1px solid rgba(10, 157, 157, 0.35);
				color: var(--teal) !important;
				font-size: 11px !important;
				letter-spacing: 0.03em;
			}
			/* Self-hosted video, preload="none" + poster so the file isn't
			   fetched until the visitor actually presses play — kept out of
			   the initial page weight on mobile. */
			.proj-video {
				display: block;
				width: 100%;
				margin-top: 12px;
				border: 1px solid var(--panel-border);
				background: #000;
			}
			/* Standard treatment for any static hero image on a project
			   card (Skate Slow, adidas FTW walls, Uncancel) — a thin teal
			   hairline, same color as the .proj-status/.proj-classified
			   accent border, so every card-level photo reads as part of
			   the same system regardless of source resolution/aspect
			   ratio. Replaced an earlier padded cream "matted print" look
			   that combined with the card's own box-shadow to read as an
			   unwanted 3D/beveled effect. */
			.proj-frame {
				margin-top: 12px;
				border: 1px solid rgba(10, 157, 157, 0.35);
			}
			.proj-frame img {
				display: block;
				width: 100%;
				height: auto;
			}
			/* Stand-in for case-study cards with no imagery to show yet (NDA,
			   etc.) — fills the same visual footprint a .proj-video/.proj-frame
			   would take so the card doesn't read as broken/empty next to
			   siblings that do have media, while doubling down on the
			   "classified briefing" joke already established by .proj-status. */
			.proj-classified {
				display: flex;
				align-items: center;
				justify-content: center;
				margin-top: 12px;
				aspect-ratio: 16 / 9;
				border: 1px solid rgba(10, 157, 157, 0.35);
				background-image: repeating-linear-gradient(
					45deg,
					rgba(10, 157, 157, 0.09),
					rgba(10, 157, 157, 0.09) 10px,
					rgba(10, 157, 157, 0.03) 10px,
					rgba(10, 157, 157, 0.03) 20px
				);
			}
			.proj-classified span {
				font-size: 11px;
				letter-spacing: 0.08em;
				color: var(--teal);
				opacity: 0.75;
			}
			/* YouTube click-to-load facade (see inline script) — a static
			   thumbnail + play glyph standing in for the real embed until
			   clicked. */
			.proj-embed {
				position: relative;
				display: block;
				width: 100%;
				aspect-ratio: 16 / 9;
				margin-top: 12px;
				border: 1px solid var(--panel-border);
				background: #000;
				overflow: hidden;
				cursor: pointer;
			}
			.proj-embed img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				display: block;
				opacity: 0.85;
			}
			.proj-embed-play {
				position: absolute;
				inset: 0;
				display: flex;
				align-items: center;
				justify-content: center;
			}
			.proj-embed-play::before {
				content: "";
				width: 0;
				height: 0;
				border-style: solid;
				border-width: 12px 0 12px 20px;
				border-color: transparent transparent transparent #fff;
				filter: drop-shadow(0 2px 6px rgba(0, 0, 0, 0.5));
			}

			/* Tag clouds sit directly on the scene (not inside a blurred
			   panel), so each tag uses the slightly more opaque --chip-bg
			   rather than --panel-bg — legible over a pale day sky or a dark
			   night sky without needing its own backdrop-filter (cheaper on
			   mobile than blurring ~20 small chips individually). */
			.tag-cloud {
				list-style: none;
				display: flex;
				flex-wrap: wrap;
				gap: 8px;
				padding: 0;
				margin: 0 0 8px;
			}
			.tag-cloud li {
				background: var(--chip-bg);
				color: var(--purple);
				border: 1px solid var(--panel-border);
				font-family: var(--mono);
				font-size: 12px;
				padding: 6px 12px;
			}
			/* Same marker-glyph language as .project-card h3::before, applied
			   to tag chips (map-screen reference pass). */
			.tag-cloud li::before {
				content: "";
				display: inline-block;
				width: 5px;
				height: 5px;
				margin-right: 6px;
				background: var(--purple);
				vertical-align: middle;
			}

			.resume-card {
				margin-top: 8px;
			}
			.exp-list {
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.exp-item + .exp-item {
				margin-top: 20px;
				padding-top: 20px;
				border-top: 1px solid var(--panel-border);
			}
			.exp-head {
				display: flex;
				flex-wrap: wrap;
				align-items: baseline;
				gap: 4px 10px;
				margin-bottom: 6px;
			}
			.exp-role {
				font-family: var(--display);
				font-weight: 600;
				font-size: 1rem;
			}
			.exp-org {
				color: var(--teal);
				font-size: 12px;
			}
			.exp-date {
				color: var(--panel-text-dim);
				font-size: 12px;
				margin-left: auto;
			}
			.exp-item p {
				color: var(--panel-text-dim);
				margin: 0;
				line-height: 1.55;
				font-size: 0.92rem;
			}
			.exp-earlier {
				margin: 18px 0 0;
				color: var(--panel-text-dim);
				font-size: 0.85rem;
				font-style: italic;
			}
			.divider {
				border: none;
				border-top: 1px solid var(--panel-border);
				margin: 24px 0;
			}
			.term-list-dark {
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.term-list-dark li {
				font-family: var(--mono);
				font-size: 0.92rem;
				color: var(--panel-text-dim);
				padding: 3px 0;
			}
			.term-list-dark li::before {
				content: "> ";
				color: var(--teal);
			}
			.lang-line {
				font-family: var(--mono);
				font-size: 0.92rem;
				color: var(--panel-text-dim);
				margin: 3px 0;
			}

			/* Unlike proj-link/tag-cloud, this link sits directly in .panel
			   (not .panel-body or a chip), so it has no opaque surface under
			   it by default — just the raw fixed scene canvas showing
			   through. That's what made it unreadable: text color alone
			   can't fix contrast against a background that shifts with
			   time-of-day. Give it the same chip-bg surface every other
			   scene-floating label uses. */
			.resume-link {
				display: inline-block;
				margin-top: 24px;
				background: var(--chip-bg);
				color: var(--teal);
				text-decoration: none;
				font-size: 13px;
				border: 1px solid var(--panel-border);
				padding: 10px 18px;
				backdrop-filter: blur(14px);
				-webkit-backdrop-filter: blur(14px);
			}
			.resume-link:hover {
				background: rgba(10, 157, 157, 0.12);
			}

			.contact-list a {
				color: var(--panel-text);
				text-decoration: none;
			}
			.contact-list a:hover {
				color: var(--teal);
			}

			.site-footer {
				text-align: center;
				color: var(--text-dim);
				font-size: 12px;
				padding: 32px 24px 56px;
			}

			@media (max-width: 640px) {
				.panel {
					padding: 56px 18px;
				}
				.panel-body,
				.project-card {
					padding: 18px;
				}
				.exp-date {
					margin-left: 0;
				}
			}
		</style>
	</body>
</html>
